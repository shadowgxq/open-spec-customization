{
  "format": "figma-plugin-api-source-summary-json",
  "sourceUrl": "https://www.figma.com/design/<fileKey>/<fileName>?node-id=<node-id>&m=dev",
  "fileKey": "<figma-file-key>",
  "nodeId": "<figma-node-id>",
  "capturedAt": "<ISO-8601 timestamp>",
  "captureMethod": "figma.use_figma Plugin API compact serializer",
  "note": "Concise source summary from Figma Plugin API. Preserves main node structure, bounds, styles, and text content. Not a complete .fig file.",
  "root": {
    "id": "<node-id>",
    "name": "<screen-name>",
    "type": "FRAME",
    "box": [0, 0, 375, 812],
    "fills": ["#ffffff"],
    "topLevelNodes": [
      {
        "id": "<child-node-id>",
        "name": "<layer-name>",
        "type": "TEXT",
        "box": [24, 88, 327, 24],
        "text": "Example label",
        "font": "Inter/Regular",
        "fontSize": 16,
        "fills": ["#000000"]
      }
    ]
  }
}
